<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.TodoMapper">

  <delete id="deleteByUserId">
    DELETE FROM todos
    WHERE user_id = #{userId}
  </delete>
</mapper>
